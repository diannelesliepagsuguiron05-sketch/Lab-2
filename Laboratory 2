# Lab 2: User Input and Logic Operations

def run_lab_activities():
    print("--- Smart Calculator ---")
    # Using input() with float conversion to handle all number types
    num1 = float(input("Enter first number: "))
    num2 = float(input("Enter second number: "))
    
    result = num1 + num2
    # Displaying formatted output using f-strings for precision
    print(f"The sum of {num1} and {num2} is: {result:.2f}\n")

    print("--- Average Calculator ---")
    val1 = float(input("Value A: "))
    val2 = float(input("Value B: "))
    
    average = (val1 + val2) / 2
    print(f"The computed average is: {average}\n")

    print("--- Grade Evaluator ---")
    # Pass or Fail System
    score = float(input("Enter student grade: "))
    
    if score >= 75:
        status = "PASSED"
    else:
        status = "FAILED"
    
    print(f"Result: {status}\n")

if __name__ == "__main__":
    run_lab_activities()
